generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  pending
  pending_review
  enrolled_student
  rejected
  suspended
  // Deprecated: vestigial enum value kept so historical role-change
  // audit log entries continue to resolve. New users are never created
  // with this role; teacher CAPABILITY is now controlled by the
  // `isTeacher` boolean on User, which can co-exist with any role
  // (so a senior student can attend classes AND teach others).
  teacher
  admin
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique
  passwordHash      String    @map("password_hash")
  firstName         String    @map("first_name")
  lastName          String    @map("last_name")
  country           String
  phone             String?
  whatsapp          String?
  telegram          String?
  enrollmentMessage String?   @map("enrollment_message") @db.VarChar(500)
  preferredLanguage String    @default("ar") @map("preferred_language")
  // How much is expected from this student per calendar month. Minor units
  // (piastres / cents) to match Payment.amount. Null = no expectation set
  // and no balance pill will render.
  expectedMonthlyAmount   Int?    @map("expected_monthly_amount")
  expectedMonthlyCurrency String? @map("expected_monthly_currency")
  role              UserRole  @default(pending)
  // Teacher capability flag. Independent of `role` so a senior
  // enrolled_student can also teach. Anyone with isTeacher=true (or
  // role=admin) gains scoped access to /admin and the assigned-students
  // surfaces. Sheikh-toggled from the dashboard; defaults to false.
  isTeacher         Boolean   @default(false) @map("is_teacher")
  emailVerified     Boolean   @default(false) @map("email_verified")
  tokenVersion      Int       @default(0) @map("token_version")
  failedLoginAttempts Int     @default(0) @map("failed_login_attempts")
  lockedUntil       DateTime? @map("locked_until")
  lastLoginAt       DateTime? @map("last_login_at")
  lastLoginIp       String?   @map("last_login_ip")
  rejectedAt        DateTime? @map("rejected_at")
  rejectionMessage  String?   @map("rejection_message")
  enrolledAt        DateTime? @map("enrolled_at")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  sessions          Session[]
  adminNotes        AdminNote[]    @relation("StudentNotes")
  authoredNotes     AdminNote[]    @relation("AuthorNotes")
  classAssignments  ClassAssignment[]
  createdClasses    ClassSession[]     @relation("AdminClasses")
  emailTokens       EmailToken[]
  auditLogs         AuditLog[]
  classLogs         ClassLog[]     @relation("ClassLogStudent")
  classLogsAuthored ClassLog[]     @relation("ClassLogAuthor")
  payments          Payment[]      @relation("PaymentStudent")
  paymentsAuthored  Payment[]      @relation("PaymentAuthor")
  googleCalendarConnection GoogleCalendarConnection?
  // Multi-teacher: which students this user (as a teacher) is assigned to.
  taughtStudents       TeacherStudent[] @relation("TeacherToStudents")
  // Multi-teacher: which teachers this user (as a student) reports to.
  teachers             TeacherStudent[] @relation("StudentToTeachers")
  // Multi-teacher: TeacherStudent rows this user (as an admin) assigned.
  assignedTeacherLinks TeacherStudent[] @relation("TeacherStudentAssigner")

  @@index([role])
  @@index([isTeacher])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("users")
}

model Session {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  refreshToken  String   @unique @map("refresh_token")
  deviceInfo    String?  @map("device_info")
  ipAddress     String?  @map("ip_address")
  lastActiveAt  DateTime @default(now()) @map("last_active_at")
  absoluteExpiry DateTime @map("absolute_expiry")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model EmailToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  type      String   // "verification" | "password_reset"
  used      Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId, type])
  @@map("email_tokens")
}

model ClassSession {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  titleAr         String?  @map("title_ar")
  description     String?  @db.Text
  descriptionAr   String?  @map("description_ar") @db.Text
  // Subject area being taught. Drives the color-coding + legend in the
  // admin calendar. Free-form string rather than an enum so we can add
  // new subjects (e.g. "seerah", "tafseer") without a migration.
  // Null for classes scheduled before this field existed.
  subject         String?
  // Mixed-subject sessions (e.g. "Quran for the first hour, Fiqh for the
  // second"). When subjectSecondary is set, subjectSwitchMin must be set
  // too. Validated in Zod at the API layer. See the Google Calendar
  // integration plan for the full constraint set.
  subjectSecondary String?  @map("subject_secondary")
  subjectSwitchMin Int?     @map("subject_switch_min")
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  timezone        String   @default("UTC")
  meetingLink     String?  @map("meeting_link")
  // Google Calendar sync — populated once the Calendar API has created the
  // event. Null before sync, or while disconnected / migrating. The
  // `meetingLink` above is updated to the Meet URL when this is set.
  googleEventId       String?   @map("google_event_id")
  googleEventSyncedAt DateTime? @map("google_event_synced_at")
  recurrence      String?  // "weekly" | "biweekly" | "custom" | null (one-off)
  recurrenceEnd   DateTime? @map("recurrence_end")
  cancelled       Boolean  @default(false)
  cancelledAt     DateTime? @map("cancelled_at")
  rescheduled       Boolean   @default(false)
  rescheduledAt     DateTime? @map("rescheduled_at")
  originalStartTime DateTime? @map("original_start_time")
  originalEndTime   DateTime? @map("original_end_time")
  reminder30SentAt  DateTime? @map("reminder_30_sent_at")
  reminder24SentAt  DateTime? @map("reminder_24_sent_at")
  // Groups all ClassSession rows created together via /classes/batch so
  // admin actions can act on "this occurrence" vs "this and following".
  // Null for legacy or one-off classes.
  seriesId          String?   @map("series_id") @db.Uuid
  createdByAdminId String? @map("created_by_admin_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdByAdmin  User?    @relation("AdminClasses", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  assignments     ClassAssignment[]
  classLogs       ClassLog[]
  googleSyncOps   GoogleCalendarSyncOp[]

  @@index([startTime])
  @@index([cancelled])
  @@index([createdByAdminId])
  @@index([seriesId])
  @@map("class_sessions")
}

// A per-admin OAuth connection to Google Calendar. Created when the admin
// clicks "Connect Google Calendar" in the Scheduling tab, swapped for a
// refresh token + initial access token via the Authorization Code flow.
// Tokens are encrypted at rest with AES-256-GCM using TOKEN_ENCRYPTION_KEY.
// If the connection is disconnected the tokens are wiped and the row is
// kept with status='disconnected' for audit; reconnecting updates in place.
model GoogleCalendarConnection {
  id                      String    @id @default(uuid()) @db.Uuid
  userId                  String    @unique @map("user_id") @db.Uuid
  googleAccountEmail      String    @map("google_account_email")
  googleCalendarId        String    @default("primary") @map("google_calendar_id")
  encryptedRefreshToken   String?   @map("encrypted_refresh_token") @db.Text
  encryptedAccessToken    String?   @map("encrypted_access_token") @db.Text
  accessTokenExpiresAt    DateTime? @map("access_token_expires_at")
  // "active" | "needs_reconnect" | "disconnected"
  status                  String    @default("active")
  // Space-separated list of scopes granted by the user. Used on reconnect
  // to detect scope changes and re-prompt if needed.
  scopes                  String    @default("")
  // Reserved for a future opt-in feature: adding students as attendees on
  // the Google Calendar event. Out of scope for the initial integration.
  inviteStudents          Boolean   @default(false) @map("invite_students")
  connectedAt             DateTime  @default(now()) @map("connected_at")
  lastSyncedAt            DateTime? @map("last_synced_at")
  lastErrorAt             DateTime? @map("last_error_at")
  lastErrorMessage        String?   @map("last_error_message") @db.Text
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_calendar_connections")
}

// Queued sync operation for a class session. A row is created whenever a
// class is scheduled / rescheduled / cancelled via the admin UI, and the
// background job drains pending rows against the Google Calendar API with
// exponential-backoff retries. See the integration plan for the full retry
// semantics. Uses atomic claim on update to survive rolling deploys.
model GoogleCalendarSyncOp {
  id             String       @id @default(uuid()) @db.Uuid
  classSessionId String       @map("class_session_id") @db.Uuid
  // "create" | "update" | "cancel"
  op             String
  attemptCount   Int          @default(0) @map("attempt_count")
  lastAttemptAt  DateTime?    @map("last_attempt_at")
  nextAttemptAt  DateTime     @default(now()) @map("next_attempt_at")
  errorMessage   String?      @map("error_message") @db.Text
  resolved       Boolean      @default(false)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  classSession   ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@index([resolved, nextAttemptAt])
  @@index([classSessionId])
  @@map("google_calendar_sync_ops")
}

model ClassAssignment {
  id             String       @id @default(uuid()) @db.Uuid
  classSessionId String       @map("class_session_id") @db.Uuid
  studentId      String       @map("student_id") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at")

  classSession   ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  student        User         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classSessionId, studentId])
  @@index([studentId])
  @@map("class_assignments")
}

// Many-to-many between teacher users (User.role='teacher') and student users
// (User.role='enrolled_student'). Drives the scope filter: teachers see only
// classes whose attendees include any of THEIR linked students, plus any
// class they personally created. The sheikh (role='admin') bypasses this
// table entirely. A student can be linked to multiple teachers (Quran with
// one, Arabic with another). `assignedByAdminId` records which admin
// assigned the relationship for audit purposes.
model TeacherStudent {
  id                String   @id @default(uuid()) @db.Uuid
  teacherId         String   @map("teacher_id") @db.Uuid
  studentId         String   @map("student_id") @db.Uuid
  assignedByAdminId String?  @map("assigned_by_admin_id") @db.Uuid
  notes             String?  @db.Text
  assignedAt        DateTime @default(now()) @map("assigned_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  teacher           User     @relation("TeacherToStudents", fields: [teacherId], references: [id], onDelete: Cascade)
  student           User     @relation("StudentToTeachers", fields: [studentId], references: [id], onDelete: Cascade)
  assignedByAdmin   User?    @relation("TeacherStudentAssigner", fields: [assignedByAdminId], references: [id], onDelete: SetNull)

  @@unique([teacherId, studentId])
  @@index([teacherId])
  @@index([studentId])
  @@map("teacher_students")
}

model AdminNote {
  id        String   @id @default(uuid()) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student   User     @relation("StudentNotes", fields: [studentId], references: [id], onDelete: Cascade)
  author    User     @relation("AuthorNotes", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("admin_notes")
}

// Per-class per-student lesson report. One row per (classSessionId, studentId).
// Upsert on edit. `summary` / `homework` / `nextSteps` are student-visible
// when `visibility='student'`. `adminNotes` is always admin-only.
model ClassLog {
  id             String       @id @default(uuid()) @db.Uuid
  classSessionId String       @map("class_session_id") @db.Uuid
  studentId      String       @map("student_id") @db.Uuid
  authorId       String       @map("author_id") @db.Uuid
  summary        String       @default("") @db.Text
  homework       String       @default("") @db.Text
  nextSteps      String       @default("") @map("next_steps") @db.Text
  adminNotes     String       @default("") @map("admin_notes") @db.Text
  // 'private' (admin only) or 'student' (student sees summary/homework/next,
  // never adminNotes). Default private so nothing leaks accidentally.
  visibility     String       @default("private")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  classSession   ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  student        User         @relation("ClassLogStudent", fields: [studentId], references: [id], onDelete: Cascade)
  author         User         @relation("ClassLogAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([classSessionId, studentId])
  @@index([studentId, createdAt])
  @@map("class_logs")
}

// Payment ledger. Amount stored in minor units (piastres) to avoid floats.
model Payment {
  id        String   @id @default(uuid()) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  amount    Int      // minor units (e.g. piastres for EGP, cents for USD)
  currency  String   @default("EGP")
  period    String   // free-form: "April 2026", "4-week package", etc.
  paidAt    DateTime @map("paid_at")
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student   User     @relation("PaymentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  author    User     @relation("PaymentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([studentId, paidAt])
  @@map("payments")
}

model Announcement {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  titleAr   String?  @map("title_ar")
  content   String   @db.Text
  contentAr String?  @map("content_ar") @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("announcements")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  details   String?  @db.Text
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model StudentCountCache {
  id        String   @id @default("singleton")
  count     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("student_count_cache")
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model AvailabilitySlot {
  id        String   @id @default(uuid()) @db.Uuid
  dayOfWeek Int      @map("day_of_week") // 0=Sunday, 1=Monday ... 6=Saturday
  startHour Int      @map("start_hour")  // 0-23
  startMin  Int      @default(0) @map("start_min") // 0-59
  endHour   Int      @map("end_hour")    // 0-23
  endMin    Int      @default(0) @map("end_min")    // 0-59
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([dayOfWeek])
  @@map("availability_slots")
}

model AvailabilityOverride {
  id        String   @id @default(uuid()) @db.Uuid
  date      DateTime @db.Date // the specific date to override
  available Boolean  @default(false) // false = day off, true = extra availability
  startHour Int?     @map("start_hour") // only used if available=true
  startMin  Int?     @default(0) @map("start_min")
  endHour   Int?     @map("end_hour")
  endMin    Int?     @default(0) @map("end_min")
  reason    String?  @db.VarChar(200) // e.g. "Holiday", "Travel"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([date])
  @@map("availability_overrides")
}
