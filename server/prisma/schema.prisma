generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  pending
  pending_review
  enrolled_student
  rejected
  suspended
  admin
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique
  passwordHash      String    @map("password_hash")
  firstName         String    @map("first_name")
  lastName          String    @map("last_name")
  country           String
  phone             String?
  whatsapp          String?
  telegram          String?
  enrollmentMessage String?   @map("enrollment_message") @db.VarChar(500)
  preferredLanguage String    @default("ar") @map("preferred_language")
  // How much is expected from this student per calendar month. Minor units
  // (piastres / cents) to match Payment.amount. Null = no expectation set
  // and no balance pill will render.
  expectedMonthlyAmount   Int?    @map("expected_monthly_amount")
  expectedMonthlyCurrency String? @map("expected_monthly_currency")
  role              UserRole  @default(pending)
  emailVerified     Boolean   @default(false) @map("email_verified")
  tokenVersion      Int       @default(0) @map("token_version")
  failedLoginAttempts Int     @default(0) @map("failed_login_attempts")
  lockedUntil       DateTime? @map("locked_until")
  lastLoginAt       DateTime? @map("last_login_at")
  lastLoginIp       String?   @map("last_login_ip")
  rejectedAt        DateTime? @map("rejected_at")
  rejectionMessage  String?   @map("rejection_message")
  enrolledAt        DateTime? @map("enrolled_at")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  sessions          Session[]
  adminNotes        AdminNote[]    @relation("StudentNotes")
  authoredNotes     AdminNote[]    @relation("AuthorNotes")
  classAssignments  ClassAssignment[]
  createdClasses    ClassSession[]     @relation("AdminClasses")
  emailTokens       EmailToken[]
  auditLogs         AuditLog[]
  classLogs         ClassLog[]     @relation("ClassLogStudent")
  classLogsAuthored ClassLog[]     @relation("ClassLogAuthor")
  payments          Payment[]      @relation("PaymentStudent")
  paymentsAuthored  Payment[]      @relation("PaymentAuthor")

  @@index([role])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("users")
}

model Session {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  refreshToken  String   @unique @map("refresh_token")
  deviceInfo    String?  @map("device_info")
  ipAddress     String?  @map("ip_address")
  lastActiveAt  DateTime @default(now()) @map("last_active_at")
  absoluteExpiry DateTime @map("absolute_expiry")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model EmailToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  type      String   // "verification" | "password_reset"
  used      Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId, type])
  @@map("email_tokens")
}

model ClassSession {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  titleAr         String?  @map("title_ar")
  description     String?  @db.Text
  descriptionAr   String?  @map("description_ar") @db.Text
  // Subject area being taught. Drives the color-coding + legend in the
  // admin calendar. Free-form string rather than an enum so we can add
  // new subjects (e.g. "seerah", "tafseer") without a migration.
  // Null for classes scheduled before this field existed.
  subject         String?
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  timezone        String   @default("UTC")
  meetingLink     String?  @map("meeting_link")
  recurrence      String?  // "weekly" | "biweekly" | "custom" | null (one-off)
  recurrenceEnd   DateTime? @map("recurrence_end")
  cancelled       Boolean  @default(false)
  cancelledAt     DateTime? @map("cancelled_at")
  rescheduled       Boolean   @default(false)
  rescheduledAt     DateTime? @map("rescheduled_at")
  originalStartTime DateTime? @map("original_start_time")
  originalEndTime   DateTime? @map("original_end_time")
  reminder30SentAt  DateTime? @map("reminder_30_sent_at")
  reminder24SentAt  DateTime? @map("reminder_24_sent_at")
  // Groups all ClassSession rows created together via /classes/batch so
  // admin actions can act on "this occurrence" vs "this and following".
  // Null for legacy or one-off classes.
  seriesId          String?   @map("series_id") @db.Uuid
  createdByAdminId String? @map("created_by_admin_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdByAdmin  User?    @relation("AdminClasses", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  assignments     ClassAssignment[]
  classLogs       ClassLog[]

  @@index([startTime])
  @@index([cancelled])
  @@index([createdByAdminId])
  @@index([seriesId])
  @@map("class_sessions")
}

model ClassAssignment {
  id             String       @id @default(uuid()) @db.Uuid
  classSessionId String       @map("class_session_id") @db.Uuid
  studentId      String       @map("student_id") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at")

  classSession   ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  student        User         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classSessionId, studentId])
  @@index([studentId])
  @@map("class_assignments")
}

model AdminNote {
  id        String   @id @default(uuid()) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student   User     @relation("StudentNotes", fields: [studentId], references: [id], onDelete: Cascade)
  author    User     @relation("AuthorNotes", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("admin_notes")
}

// Per-class per-student lesson report. One row per (classSessionId, studentId).
// Upsert on edit. `summary` / `homework` / `nextSteps` are student-visible
// when `visibility='student'`. `adminNotes` is always admin-only.
model ClassLog {
  id             String       @id @default(uuid()) @db.Uuid
  classSessionId String       @map("class_session_id") @db.Uuid
  studentId      String       @map("student_id") @db.Uuid
  authorId       String       @map("author_id") @db.Uuid
  summary        String       @default("") @db.Text
  homework       String       @default("") @db.Text
  nextSteps      String       @default("") @map("next_steps") @db.Text
  adminNotes     String       @default("") @map("admin_notes") @db.Text
  // 'private' (admin only) or 'student' (student sees summary/homework/next,
  // never adminNotes). Default private so nothing leaks accidentally.
  visibility     String       @default("private")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  classSession   ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  student        User         @relation("ClassLogStudent", fields: [studentId], references: [id], onDelete: Cascade)
  author         User         @relation("ClassLogAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([classSessionId, studentId])
  @@index([studentId, createdAt])
  @@map("class_logs")
}

// Payment ledger. Amount stored in minor units (piastres) to avoid floats.
model Payment {
  id        String   @id @default(uuid()) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  amount    Int      // minor units (e.g. piastres for EGP, cents for USD)
  currency  String   @default("EGP")
  period    String   // free-form: "April 2026", "4-week package", etc.
  paidAt    DateTime @map("paid_at")
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student   User     @relation("PaymentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  author    User     @relation("PaymentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([studentId, paidAt])
  @@map("payments")
}

model Announcement {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  titleAr   String?  @map("title_ar")
  content   String   @db.Text
  contentAr String?  @map("content_ar") @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("announcements")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  details   String?  @db.Text
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model StudentCountCache {
  id        String   @id @default("singleton")
  count     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("student_count_cache")
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model AvailabilitySlot {
  id        String   @id @default(uuid()) @db.Uuid
  dayOfWeek Int      @map("day_of_week") // 0=Sunday, 1=Monday ... 6=Saturday
  startHour Int      @map("start_hour")  // 0-23
  startMin  Int      @default(0) @map("start_min") // 0-59
  endHour   Int      @map("end_hour")    // 0-23
  endMin    Int      @default(0) @map("end_min")    // 0-59
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([dayOfWeek])
  @@map("availability_slots")
}

model AvailabilityOverride {
  id        String   @id @default(uuid()) @db.Uuid
  date      DateTime @db.Date // the specific date to override
  available Boolean  @default(false) // false = day off, true = extra availability
  startHour Int?     @map("start_hour") // only used if available=true
  startMin  Int?     @default(0) @map("start_min")
  endHour   Int?     @map("end_hour")
  endMin    Int?     @default(0) @map("end_min")
  reason    String?  @db.VarChar(200) // e.g. "Holiday", "Travel"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([date])
  @@map("availability_overrides")
}
